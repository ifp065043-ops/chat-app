# ===================================================
# قالب متغيرات الإنتاج — انسخ كل سطر إلى لوحة المتغيرات
# في Railway / Render / VPS (أو انسخ الملف كاملاً إلى .env على السيرفر)
# لا ترفع هذا الملف بقيم حقيقية؛ القيم أدناه أمثلة فقط.
# ===================================================

# إلزامي: رابط MongoDB (Atlas)
# الصيغة: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/chatapp?retryWrites=true&w=majority
# استبدل USER وPASSWORD واسم المجموعة؛ إن احتوى كلمة المرور على رموز خاصة استخدم ترميز URL.
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/chatapp?retryWrites=true&w=majority

# إلزامي: مفتاح JWT عشوائي طويل (مختلف تماماً عن التطوير)
# توليد: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# يجب استبدال القيمة أدناه — السيرفر لن يعمل في production إن بقيت كما هي
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# إلزامي للإنتاج
NODE_ENV=production

# المنصات السحابية تضبط PORT تلقائياً — لا تغيّرها إلا إذا كنت على VPS وتدير المنفذ بنفسك
# PORT=3000

# الاستماع على كل الواجهات (افتراضي التطبيق 0.0.0.0 إن لم تُضبط)
HOST=0.0.0.0

# أصول مسموحة (CORS + Socket.IO + Origin checks) — ضع دومينك هنا
# مثال:
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=

# اختياري: GIF عبر Giphy في الإنتاج
GIPHY_API_KEY=

# مشرفو الحظر (فاصلة بين الأسماء) — POST /api/admin/ban-month | /api/admin/unban مع Bearer أو كوكي الجلسة
ADMIN_USERNAMES=

# يُنصح بتفعيله في الإنتاج: لا دخول قبل تأكيد البريد
# REQUIRE_EMAIL_VERIFIED=1

# Redis (اختياري): لتفعيل حظر موزّع للـIP (مفيد مع تعدد النسخ)
REDIS_URL=

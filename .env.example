# ===================================================
# انسخ هذا الملف وسمّه .env ثم عدّل القيم
#   npm run env:init
# أو: cp .env.example .env
# للإنتاج راجع .env.production.example وملف DEPLOY.md
# ===================================================

# رابط MongoDB - غيّره إذا كانت قاعدة البيانات على سيرفر خارجي
MONGO_URI=mongodb://localhost:27017/chatapp

# Windows + mongodb+srv: إن ظهر خطأ querySrv ECONNREFUSED السيرفر يستخدم DNS عاماً تلقائياً.
# إن منعتك شبكة الشركة من 8.8.8.8 ضع: MONGO_SKIP_DNS_FIX=1
# MONGO_SKIP_DNS_FIX=

# مفتاح سري لـ JWT - يجب أن يكون طويلاً وعشوائياً ولا تشاركه أحداً
# يمكنك توليده بـ: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# بيئة التشغيل: development أو production (للكوكيز الآمنة و Helmet)
NODE_ENV=development

# رقم المنفذ (اختياري، الافتراضي 3000؛ المنصات السحابية غالباً تضبط PORT تلقائياً)
PORT=3000

# عنوان الاستماع (للنشر: 0.0.0.0 حتى يقبل الاتصال من خارج الحاوية؛ محلياً يمكن تركه فارغاً)
HOST=0.0.0.0

# أصول مسموحة (CORS + Socket.IO + Origin checks) — اتركه فارغاً محلياً
# مثال:
# ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
ALLOWED_ORIGINS=

# اختياري: مفتاح Giphy — أنشئ حساباً مجانياً ثم أنشئ تطبيقاً من:
# https://developers.giphy.com/dashboard/
# انسخ "API Key" والصقه بعد الإشارة = (بدون مسافات أو علامات اقتباس)
# بدون مفتاح يُستخدم قائمة GIF محلية فقط
GIPHY_API_KEY=

# أسماء حسابات المشرفين (مفصولة بفاصلة) — لاستدعاء /api/admin/ban-month و /api/admin/unban
# مثال: ADMIN_USERNAMES=admin1,moderator2
ADMIN_USERNAMES=

# إن كانت 1 أو true: لا يُسمح بتسجيل الدخول قبل تأكيد البريد (مناسب للإنتاج)
# REQUIRE_EMAIL_VERIFIED=1

# Redis (اختياري): لتفعيل حظر موزّع للـIP (مفيد مع تعدد السيرفرات)
# مثال:
# REDIS_URL=redis://default:password@host:6379
# REDIS_URL=rediss://... (SSL)
REDIS_URL=

# عدد بوتات الغرف (افتراضي 80)
# BOT_COUNT=80
